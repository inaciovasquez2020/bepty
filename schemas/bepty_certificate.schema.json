{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BEpTy Certificate",
  "description": "Canonical proof of residual valuation and local vanishing",
  "type": "object",
  "properties": {
    "certificate_version": { "type": "string", "const": "v0.2.0" },
    "object_type": { "type": "string", "enum": ["graph", "simplicial_complex"] },
    "valuation": { "type": "string", "enum": ["dim", "entropy", "euler"] },
    "radius": { "type": "number", "minimum": 0 },
    "graph_A": { "type": "object" },
    "graph_B": { "type": "object" },
    "xR_vanishes": { "boolean": true },
    "beta_value": { "type": "integer" },
    "profile_A": { "type": "object" },
    "profile_B": { "type": "object" },
    "hash": { "type": "string" }
  },
  "required": ["certificate_version", "object_type", "valuation", "radius", "xR_vanishes", "beta_value", "hash"]
}
